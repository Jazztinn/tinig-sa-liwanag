OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=aya:8b
OLLAMA_TIMEOUT_MS=25000
# Set to 1 to skip Ollama and use seed/phrase/dictionary fallback only.
OLLAMA_DISABLED=0

# Hosted speech demo ASR. Defaults to the Hugging Face Space submodule app.
HF_SPACE_TRANSCRIBE_URL=https://alinuxperson-tinig-sa-liwanag-space.hf.space
HF_SPACE_TRANSCRIBE_API_NAME=transcribe_base64
HF_SPACE_TRANSCRIBE_TIMEOUT_MS=120000
TRANSCRIBE_MAX_AUDIO_BYTES=8388608
