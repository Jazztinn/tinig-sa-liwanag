OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=aya:8b
OLLAMA_TIMEOUT_MS=25000
# Set to 1 to skip Ollama and use seed/phrase/dictionary fallback only.
OLLAMA_DISABLED=0

# Local speech demo ASR. Uses local ffmpeg + openai-whisper CLI, no external API.
LOCAL_FFMPEG_BIN=ffmpeg
LOCAL_WHISPER_BIN=whisper
LOCAL_WHISPER_MODEL=small
LOCAL_WHISPER_LANGUAGE=tl
LOCAL_TRANSCRIBE_TIMEOUT_MS=120000
